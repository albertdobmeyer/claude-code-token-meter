{
  "name": "agent-token-meter",
  "version": "1.0.1",
  "description": "Zero-dependency burn-rate monitor for AI coding agents. Context tax, workflow phases, acceleration, compaction ETA, threshold hooks, and automatic nudges at 50/75/90% context fill. Currently supports Claude Code.",
  "type": "module",
  "bin": {
    "agent-token-meter": "token-meter.mjs",
    "claude-code-token-meter": "token-meter.mjs"
  },
  "scripts": {
    "start": "node token-meter.mjs",
    "all": "node token-meter.mjs --all"
  },
  "files": [
    "token-meter.mjs",
    "hook.mjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agent",
    "ai-coding",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "tokens",
    "monitoring",
    "burn-rate",
    "context-window",
    "cost-tracking",
    "developer-tools",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertdobmeyer/agent-token-meter.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
